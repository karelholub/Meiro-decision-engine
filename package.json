{
  "name": "decisioning-extension",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r build",
    "lint": "pnpm -r build",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @decisioning/api prisma:migrate",
    "db:seed": "pnpm --filter @decisioning/api prisma:seed",
    "bench:decide": "pnpm --filter @decisioning/api bench:decide",
    "smoke:inapp": "pnpm --filter @decisioning/api smoke:inapp",
    "drill:dependency": "pnpm --filter @decisioning/api drill:dependency",
    "release:gates": "pnpm --filter @decisioning/api prisma:generate && pnpm --filter @decisioning/api build && pnpm --filter @decisioning/api test && pnpm --filter @decisioning/api smoke:inapp",
    "docker:build": "DOCKER_BUILDKIT=1 docker buildx build -f docker/api.Dockerfile -t decisioning-api:local . --load && DOCKER_BUILDKIT=1 docker buildx build -f docker/ui.Dockerfile -t decisioning-ui:local . --load",
    "docker:build:api": "DOCKER_BUILDKIT=1 docker compose build api",
    "docker:build:ui": "DOCKER_BUILDKIT=1 docker compose build ui",
    "docker:dev": "DOCKER_BUILDKIT=1 docker compose up --build",
    "docker:up:api:fast": "DOCKER_BUILDKIT=1 docker compose up -d --no-deps --build api",
    "docker:up:ui:fast": "DOCKER_BUILDKIT=1 docker compose up -d --no-deps --build ui"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
