{
  "name": "@decisioning/sdk-web",
  "version": "0.1.0",
  "description": "Lightweight web SDK for Decisioning in-app decide and event tracking.",
  "private": false,
  "license": "UNLICENSED",
  "keywords": [
    "decisioning",
    "sdk",
    "in-app",
    "feature-flags",
    "experimentation"
  ],
  "type": "module",
  "main": "./dist/decisioning-sdk-web.esm.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/decisioning-sdk-web.esm.js",
      "default": "./dist/decisioning-sdk-web.esm.js"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "bundle": "node ./scripts/build-bundle.mjs",
    "test": "vitest run"
  }
}
