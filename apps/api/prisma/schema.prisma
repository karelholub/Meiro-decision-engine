generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DecisionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum Outcome {
  ELIGIBLE
  IN_HOLDOUT
  CAPPED
  NOT_ELIGIBLE
  ERROR
}

enum Environment {
  DEV
  STAGE
  PROD
}

enum WbsProfileIdStrategy {
  CUSTOMER_ENTITY_ID
  ATTRIBUTE_KEY
  HASH_FALLBACK
}

enum InAppCampaignStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  ARCHIVED
}

enum InAppEventType {
  IMPRESSION
  CLICK
  DISMISS
}

enum InAppUserRole {
  VIEWER
  EDITOR
  APPROVER
  ADMIN
}

enum PrecomputeRunStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
  CANCELED
}

enum DecisionResultStatus {
  READY
  SUPPRESSED
  NOOP
  ERROR
}

enum ExperimentStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum DlqTopic {
  PIPES_WEBHOOK
  PRECOMPUTE_TASK
  TRACKING_EVENT
  EXPORT_TASK
  PIPES_CALLBACK_DELIVERY
}

enum DlqStatus {
  PENDING
  RETRYING
  QUARANTINED
  RESOLVED
}

model Decision {
  id          String                      @id @default(uuid())
  environment Environment                 @default(DEV)
  key         String
  name        String
  description String                      @default("")
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  versions    DecisionVersion[]
  logs        DecisionLog[]
  evidence    DecisionAuthoringEvidence[]
  scenarios   DecisionScenarioTest[]

  @@unique([environment, key])
}

model DecisionVersion {
  id             String         @id @default(uuid())
  decisionId     String
  version        Int
  status         DecisionStatus
  definitionJson Json
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  activatedAt    DateTime?
  decision       Decision       @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@unique([decisionId, version])
  @@index([decisionId, status])
}

model DecisionStack {
  id             String         @id @default(uuid())
  environment    Environment    @default(DEV)
  key            String
  name           String
  description    String?        @default("")
  status         DecisionStatus
  version        Int
  definitionJson Json
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  activatedAt    DateTime?

  @@unique([environment, key, version])
  @@index([environment, key, status])
  @@index([environment, status, updatedAt])
  @@map("decision_stacks")
}

model DecisionStackLog {
  id               String      @id @default(uuid())
  environment      Environment @default(DEV)
  requestId        String
  stackKey         String
  version          Int
  profileId        String
  lookupAttribute  String?
  lookupValueHash  String?
  timestamp        DateTime    @default(now())
  finalActionType  String
  finalReasonsJson Json
  stepsJson        Json
  payloadJson      Json
  debugJson        Json?
  replayInputJson  Json?
  correlationId    String
  totalMs          Int

  @@index([environment, stackKey, timestamp])
  @@index([environment, profileId, timestamp])
  @@index([environment, stackKey, profileId, timestamp])
  @@index([timestamp])
  @@index([requestId])
  @@index([correlationId])
  @@map("decision_stack_logs")
}

model DecisionLog {
  id             String   @id @default(uuid())
  requestId      String
  decisionId     String
  version        Int
  profileId      String
  timestamp      DateTime @default(now())
  actionType     String
  payloadJson    Json
  outcome        Outcome
  reasonsJson    Json
  debugTraceJson Json?
  inputJson      Json?
  latencyMs      Int
  decision       Decision @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@index([decisionId, timestamp])
  @@index([profileId, timestamp])
  @@index([decisionId, profileId, timestamp])
  @@index([decisionId, outcome, timestamp])
  @@index([timestamp])
  @@index([requestId])
}

model DecisionAuthoringEvidence {
  id              String      @id @default(uuid())
  decisionId      String
  environment     Environment @default(DEV)
  version         Int?
  evidenceType    String
  status          String
  summary         String      @default("")
  payloadJson     Json
  createdByUserId String?
  createdByEmail  String?
  createdAt       DateTime    @default(now())
  decision        Decision    @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@index([decisionId, createdAt])
  @@index([environment, status, createdAt])
  @@map("decision_authoring_evidence")
}

model DecisionScenarioTest {
  id              String      @id @default(uuid())
  decisionId      String
  environment     Environment @default(DEV)
  version         Int?
  name            String
  required        Boolean     @default(true)
  enabled         Boolean     @default(true)
  profileJson     Json
  expectedJson    Json
  lastStatus      String      @default("pending")
  lastDetail      String?
  lastResultJson  Json?
  lastRunAt       DateTime?
  createdByUserId String?
  createdByEmail  String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  decision        Decision    @relation(fields: [decisionId], references: [id], onDelete: Cascade)

  @@index([decisionId, enabled, updatedAt])
  @@index([environment, lastStatus, updatedAt])
  @@map("decision_scenario_tests")
}

model Conversion {
  id         String   @id @default(uuid())
  profileId  String
  timestamp  DateTime @default(now())
  type       String
  value      Float?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([profileId, timestamp])
  @@index([type, timestamp])
}

model WbsInstance {
  id                  String      @id @default(uuid())
  environment         Environment @default(DEV)
  name                String
  baseUrl             String
  attributeParamName  String      @default("attribute")
  valueParamName      String      @default("value")
  segmentParamName    String      @default("segment")
  includeSegment      Boolean     @default(false)
  defaultSegmentValue String?
  timeoutMs           Int         @default(1500)
  isActive            Boolean     @default(true)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([environment, isActive])
  @@index([environment, updatedAt])
}

model WbsMapping {
  id                    String               @id @default(uuid())
  environment           Environment          @default(DEV)
  name                  String
  isActive              Boolean              @default(true)
  profileIdStrategy     WbsProfileIdStrategy @default(CUSTOMER_ENTITY_ID)
  profileIdAttributeKey String?
  mappingJson           Json
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([environment, isActive])
  @@index([environment, updatedAt])
}

model InAppApplication {
  id            String      @id @default(uuid())
  environment   Environment @default(DEV)
  key           String
  name          String
  platforms     Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([environment, key])
  @@index([environment, updatedAt])
  @@map("inapp_applications")
}

model InAppPlacement {
  id                  String      @id @default(uuid())
  environment         Environment @default(DEV)
  key                 String
  name                String
  description         String?
  allowedTemplateKeys Json?
  defaultTtlSeconds   Int?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@unique([environment, key])
  @@index([environment, updatedAt])
  @@map("inapp_placements")
}

model InAppTemplate {
  id         String      @id @default(uuid())
  environment Environment @default(DEV)
  key        String
  name       String
  schemaJson Json
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([environment, key])
  @@index([environment, updatedAt])
  @@map("inapp_templates")
}

model InAppCampaign {
  id                    String             @id @default(uuid())
  environment           Environment        @default(DEV)
  key                   String
  name                  String
  description           String?
  status                InAppCampaignStatus @default(DRAFT)
  appKey                String
  placementKey          String
  templateKey           String
  contentKey            String?
  offerKey              String?
  experimentKey         String?
  priority              Int                @default(0)
  ttlSeconds            Int                @default(3600)
  startAt               DateTime?
  endAt                 DateTime?
  holdoutEnabled        Boolean            @default(false)
  holdoutPercentage     Int                @default(0)
  holdoutSalt           String             @default("inapp-holdout")
  capsPerProfilePerDay  Int?
  capsPerProfilePerWeek Int?
  eligibilityAudiencesAny Json?
  tokenBindingsJson     Json?
  submittedAt           DateTime?
  lastReviewComment     String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  activatedAt           DateTime?
  variants              InAppCampaignVariant[]
  versions              InAppCampaignVersion[]

  @@unique([environment, key])
  @@index([environment, appKey, placementKey, status])
  @@index([environment, status, priority])
  @@map("inapp_campaigns")
}

model Offer {
  id          String      @id @default(uuid())
  environment Environment @default(DEV)
  key         String
  name        String
  description String?
  status      String
  version     Int
  tags        Json?
  type        String
  valueJson   Json
  constraints Json?
  startAt     DateTime?
  endAt       DateTime?
  locale      String?
  channel     String?
  placementKey String?
  tokenBindings Json?
  submittedAt DateTime?
  approvedAt  DateTime?
  approvedBy  String?
  archivedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  activatedAt DateTime?
  variants    OfferVariant[]

  @@unique([environment, key, version])
  @@index([environment, key, status])
  @@index([environment, status, updatedAt])
  @@map("offers")
}

model OfferVariant {
  id            String   @id @default(uuid())
  offerId       String
  locale        String?
  channel       String?
  placementKey  String?
  isDefault     Boolean  @default(false)
  payloadJson   Json
  tokenBindings Json?
  clonedFromVariantId String?
  experimentKey String?
  experimentVariantId String?
  experimentRole String?
  metadataJson   Json?
  startAt       DateTime?
  endAt         DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  offer         Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@index([offerId, locale, channel, placementKey])
  @@index([offerId, isDefault])
  @@map("offer_variants")
}

model ContentBlock {
  id           String      @id @default(uuid())
  environment  Environment @default(DEV)
  key          String
  name         String
  description  String?
  status       String
  version      Int
  tags         Json?
  templateId   String
  schemaJson   Json?
  localesJson  Json
  tokenBindings Json?
  startAt      DateTime?
  endAt        DateTime?
  locale       String?
  channel      String?
  placementKey String?
  submittedAt  DateTime?
  approvedAt   DateTime?
  approvedBy   String?
  archivedAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  activatedAt  DateTime?
  variants     ContentBlockVariant[]

  @@unique([environment, key, version])
  @@index([environment, key, status])
  @@index([environment, status, updatedAt])
  @@map("content_blocks")
}

model ContentBlockVariant {
  id             String       @id @default(uuid())
  contentBlockId String
  locale         String?
  channel        String?
  placementKey   String?
  isDefault      Boolean      @default(false)
  payloadJson    Json
  tokenBindings  Json?
  clonedFromVariantId String?
  experimentKey  String?
  experimentVariantId String?
  experimentRole String?
  metadataJson    Json?
  startAt        DateTime?
  endAt          DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  contentBlock   ContentBlock @relation(fields: [contentBlockId], references: [id], onDelete: Cascade)

  @@index([contentBlockId, locale, channel, placementKey])
  @@index([contentBlockId, isDefault])
  @@map("content_block_variants")
}

model AssetBundle {
  id             String      @id @default(uuid())
  environment    Environment @default(DEV)
  key            String
  name           String
  description    String?
  status         String
  version        Int
  offerKey       String?
  contentKey     String?
  templateKey    String?
  placementKeys  Json?
  channels       Json?
  locales        Json?
  tags           Json?
  useCase        String?
  metadataJson   Json?
  submittedAt    DateTime?
  approvedAt     DateTime?
  approvedBy     String?
  archivedAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  activatedAt    DateTime?

  @@unique([environment, key, version])
  @@index([environment, key, status])
  @@index([environment, status, updatedAt])
  @@map("asset_bundles")
}

model CatalogAuditLog {
  id          String      @id @default(uuid())
  environment Environment @default(DEV)
  entityType  String
  entityId    String
  entityKey   String
  version     Int?
  action      String
  actorId     String
  metaJson    Json?
  createdAt   DateTime    @default(now())

  @@index([environment, entityType, entityKey, createdAt])
  @@index([environment, entityType, entityId, createdAt])
  @@map("catalog_audit_logs")
}

model InAppCampaignVariant {
  id         String        @id @default(uuid())
  campaignId String
  variantKey String
  weight     Int
  contentJson Json
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  campaign   InAppCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, variantKey])
  @@index([campaignId, weight])
  @@map("inapp_campaign_variants")
}

model InAppImpression {
  id         String      @id @default(uuid())
  environment Environment @default(DEV)
  campaignKey String
  profileId  String
  timestamp  DateTime    @default(now())
  messageId  String

  @@index([environment, campaignKey, profileId, timestamp])
  @@index([environment, profileId, timestamp])
  @@index([messageId])
  @@map("inapp_impressions")
}

model InAppDecisionLog {
  id            String      @id @default(uuid())
  environment   Environment @default(DEV)
  campaignKey   String?
  profileId     String
  placement     String
  templateKey   String?
  variantKey    String?
  shown         Boolean
  reasonsJson   Json
  payloadJson   Json?
  replayInputJson Json?
  correlationId String
  wbsMs         Int?
  dbMs          Int?
  engineMs      Int?
  totalMs       Int?
  createdAt     DateTime    @default(now())

  @@index([environment, createdAt])
  @@index([environment, profileId, createdAt])
  @@index([environment, campaignKey, createdAt])
  @@index([createdAt])
  @@index([correlationId])
  @@map("inapp_decision_logs")
}

model InAppDecisionCache {
  id           String      @id @default(uuid())
  environment  Environment @default(DEV)
  cacheKey     String
  responseJson Json
  expiresAt    DateTime
  createdAt    DateTime    @default(now())

  @@unique([environment, cacheKey])
  @@index([environment, expiresAt])
  @@map("inapp_decision_cache")
}

model InAppEvent {
  id              String        @id @default(uuid())
  environment     Environment   @default(DEV)
  eventType       InAppEventType
  ts              DateTime      @default(now())
  appKey          String
  placement       String
  campaignKey     String
  variantKey      String
  experimentKey   String?
  experimentVersion Int?
  isHoldout       Boolean       @default(false)
  allocationId    String?
  messageId       String
  sourceStreamId  String?       @unique
  profileId       String?
  lookupAttribute String?
  lookupValueHash String?
  contextJson     Json?
  createdAt       DateTime      @default(now())

  @@index([environment, campaignKey, ts])
  @@index([environment, messageId])
  @@index([environment, appKey, placement, ts])
  @@index([environment, experimentKey, ts])
  @@index([ts])
  @@map("inapp_events")
}

model ExperimentVersion {
  id             String           @id @default(uuid())
  environment    Environment      @default(DEV)
  key            String
  version        Int
  status         ExperimentStatus
  name           String
  description    String?
  experimentJson Json
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  activatedAt    DateTime?
  startAt        DateTime?
  endAt          DateTime?

  @@unique([environment, key, version])
  @@index([environment, key, status])
  @@map("experiment_versions")
}

model ExperimentAssignment {
  id            String      @id @default(uuid())
  environment   Environment @default(DEV)
  experimentKey String
  unitType      String
  unitHash      String
  timeBucket    String
  variantId     String
  assignedAt    DateTime    @default(now())
  expiresAt     DateTime?

  @@unique([environment, experimentKey, unitType, unitHash, timeBucket])
  @@index([environment, experimentKey, assignedAt])
  @@map("experiment_assignments")
}

model ExperimentExposure {
  id                String      @id @default(uuid())
  environment       Environment @default(DEV)
  ts                DateTime    @default(now())
  appKey            String?
  placement         String?
  experimentKey     String
  experimentVersion Int
  variantId         String
  isHoldout         Boolean     @default(false)
  allocationId      String?
  profileId         String?
  unitType          String?
  unitHash          String?
  eventType         String
  messageId         String?
  campaignId        String?
  context           Json?

  @@index([environment, experimentKey, ts])
  @@index([environment, campaignId, ts])
  @@map("experiment_exposures")
}

model InAppUser {
  id        String      @id
  role      InAppUserRole @default(VIEWER)
  name      String?
  email     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  isActive  Boolean     @default(true)

  @@index([role, isActive])
  @@map("inapp_users")
}

model InAppCampaignVersion {
  id            String      @id @default(uuid())
  campaignId    String
  campaignKey   String
  environment   Environment @default(DEV)
  version       Int
  snapshotJson  Json
  authorUserId  String
  reason        String?
  createdAt     DateTime    @default(now())
  campaign      InAppCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([environment, campaignKey, version])
  @@index([campaignId, createdAt])
  @@index([environment, campaignKey, createdAt])
  @@map("inapp_campaign_versions")
}

model InAppAuditLog {
  id          String      @id @default(uuid())
  environment Environment @default(DEV)
  userId      String
  userRole    InAppUserRole
  action      String
  entityType  String
  entityId    String
  beforeHash  String?
  afterHash   String?
  metaJson    Json?
  createdAt   DateTime    @default(now())

  @@index([environment, entityType, entityId, createdAt])
  @@index([environment, userId, createdAt])
  @@index([action, createdAt])
  @@map("inapp_audit_logs")
}

model CampaignCalendarSavedView {
  id          String      @id @default(uuid())
  environment Environment @default(DEV)
  userId      String
  name        String
  view        String
  swimlane    String
  filtersJson Json
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([environment, userId, name])
  @@index([environment, userId, updatedAt])
  @@map("campaign_calendar_saved_views")
}

model CampaignCalendarReviewPack {
  id              String      @id @default(uuid())
  environment     Environment @default(DEV)
  name            String
  createdByUserId String
  view            String
  swimlane        String
  from            DateTime
  to              DateTime
  filtersJson     Json
  summaryJson     Json
  snapshotJson    Json
  campaignIdsJson Json
  createdAt       DateTime    @default(now())

  @@index([environment, createdAt])
  @@index([environment, createdByUserId, createdAt])
  @@index([environment, from, to])
  @@map("campaign_calendar_review_packs")
}

model PrecomputeRun {
  runKey      String              @id
  environment Environment         @default(DEV)
  mode        String
  key         String
  status      PrecomputeRunStatus @default(QUEUED)
  total       Int                 @default(0)
  processed   Int                 @default(0)
  succeeded   Int                 @default(0)
  noop        Int                 @default(0)
  suppressed  Int                 @default(0)
  errors      Int                 @default(0)
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime            @default(now())
  parameters  Json

  @@index([environment, createdAt])
  @@index([environment, status, createdAt])
  @@index([status, createdAt])
  @@map("precompute_runs")
}

model DecisionResult {
  id              String               @id @default(uuid())
  environment     Environment          @default(DEV)
  tenantKey       String?
  runKey          String
  decisionKey     String?
  stackKey        String?
  decisionVersion Int?
  stackVersion    Int?
  profileId       String?
  lookupAttribute String?
  lookupValue     String?
  context         Json
  actionType      String
  actionKey       String?
  payload         Json
  tracking        Json?
  ttlSeconds      Int?
  expiresAt       DateTime
  reasonCode      String?
  evidence        Json?
  debug           Json?
  status          DecisionResultStatus
  errorMessage    String?
  createdAt       DateTime             @default(now())

  @@index([runKey])
  @@index([environment, runKey, status, createdAt], map: "dr_env_run_status_created_idx")
  @@index([environment, decisionKey, profileId])
  @@index([environment, decisionKey, profileId, status, expiresAt, createdAt], map: "dr_env_decision_profile_status_exp_created_idx")
  @@index([expiresAt])
  @@index([createdAt], map: "dr_createdAt_idx")
  @@index([lookupAttribute, lookupValue])
  @@index([environment, stackKey, profileId, status, expiresAt, createdAt], map: "dr_env_stack_profile_status_exp_created_idx")
  @@index([environment, stackKey, profileId, createdAt])
  @@index([environment, decisionKey, lookupAttribute, lookupValue, status, expiresAt, createdAt], map: "dr_env_decision_lookup_status_exp_created_idx")
  @@index([environment, decisionKey, lookupAttribute, lookupValue, createdAt], map: "dr_env_decision_lookup_created_idx")
  @@map("decision_results")
}

model OrchestrationPolicy {
  id          String   @id @default(uuid())
  environment String
  appKey      String?
  key         String
  name        String
  description String?
  status      String
  version     Int
  policyJson  Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  activatedAt DateTime?

  @@unique([environment, appKey, key, version])
  @@index([environment, appKey, key, status])
  @@map("orchestration_policies")
}

model OrchestrationEvent {
  id          String   @id @default(uuid())
  environment String
  appKey      String?
  profileId   String
  ts          DateTime @default(now())
  actionType  String
  actionKey   String?
  groupKey    String?
  metadata    Json?

  @@index([environment, profileId, ts])
  @@index([environment, groupKey, ts])
  @@map("orchestration_events")
}

model AppSetting {
  id          String      @id @default(uuid())
  environment Environment @default(DEV)
  key         String
  valueJson   Json
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([environment, key])
  @@index([environment, updatedAt])
  @@map("app_settings")
}

model PipesCallbackConfig {
  id                    String      @id @default(uuid())
  environment           Environment @default(DEV)
  appKey                String?
  isEnabled             Boolean     @default(false)
  callbackUrl           String
  authType              String      @default("bearer")
  authSecret            String?
  mode                  String      @default("async_only")
  timeoutMs             Int         @default(1500)
  maxAttempts           Int         @default(8)
  includeDebug          Boolean     @default(false)
  includeProfileSummary Boolean     @default(false)
  allowPiiKeys          Json?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@unique([environment, appKey])
  @@index([environment, isEnabled])
  @@map("pipes_callback_configs")
}

model DeadLetterMessage {
  id             String    @id @default(uuid())
  topic          DlqTopic
  status         DlqStatus @default(PENDING)
  payload        Json
  payloadHash    String
  dedupeKey      String?
  errorType      String
  errorMessage   String
  errorMeta      Json?
  attempts       Int       @default(0)
  maxAttempts    Int       @default(8)
  nextRetryAt    DateTime
  firstSeenAt    DateTime  @default(now())
  lastSeenAt     DateTime  @updatedAt
  tenantKey      String?
  correlationId  String?
  source         String?
  createdBy      String?
  resolvedAt     DateTime?
  resolvedBy     String?
  resolutionNote String?

  @@index([topic, status, nextRetryAt])
  @@index([payloadHash])
  @@index([status, nextRetryAt])
  @@unique([topic, payloadHash])
  @@map("dead_letter_messages")
}

model DlqConfig {
  id              String   @id @default("dlq_config")
  enabledTopics   Json
  backoffBaseMs   Int      @default(2000)
  backoffMaxMs    Int      @default(600000)
  jitterPct       Int      @default(30)
  quarantineAfter Int      @default(8)
  updatedAt       DateTime @updatedAt

  @@map("dlq_config")
}

model User {
  id          String        @id @default(uuid())
  email       String        @unique
  name        String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  envRoles    UserEnvRole[]
}

model Role {
  id          String        @id @default(uuid())
  key         String        @unique
  name        String
  description String?
  permissions Json
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  envRoles    UserEnvRole[]
}

model UserEnvRole {
  id        String   @id @default(uuid())
  userId    String
  env       String
  roleId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id])

  @@unique([userId, env, roleId])
  @@index([env])
}

model AuditEvent {
  id            String   @id @default(uuid())
  ts            DateTime @default(now())
  env           String?
  actorUserId   String?
  actorEmail    String?
  action        String
  entityType    String?
  entityKey     String?
  entityVersion Int?
  metadata      Json?

  @@index([ts])
  @@index([env, action])
  @@index([entityType, entityKey])
}

model Release {
  id               String   @id @default(uuid())
  sourceEnv        String
  targetEnv        String
  key              String
  status           String
  createdByUserId  String?
  createdByEmail   String?
  approvalByUserId String?
  approvalNote     String?
  appliedByUserId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  summary          String?
  planJson         Json
}
