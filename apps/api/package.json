{
  "name": "@decisioning/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "bench:decide": "tsx scripts/bench-decide.ts",
    "validate:meiro-campaigns": "node --import tsx scripts/validate-meiro-campaign-control.ts",
    "smoke:inapp": "node --import tsx scripts/load-smoke-inapp-v2.ts",
    "drill:dependency": "node --import tsx scripts/incident-drill-dependency.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "sh -c 'set -a; [ -f ../../.env ] && . ../../.env; set +a; prisma migrate deploy'",
    "prisma:seed": "tsx prisma/seed.ts",
    "start:docker": "prisma migrate deploy && prisma generate && tsx prisma/seed.ts && tsx src/index.ts"
  },
  "dependencies": {
    "@decisioning/dsl": "workspace:*",
    "@decisioning/engine": "workspace:*",
    "@decisioning/meiro": "workspace:*",
    "@decisioning/policies": "workspace:*",
    "@decisioning/shared": "workspace:*",
    "@decisioning/wbs-mapping": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@prisma/client": "^6.2.1",
    "fastify": "^5.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
